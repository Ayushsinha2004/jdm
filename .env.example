# Engine Supabase connection (from your .env in the parent project)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# The solution ID for this specific client deployment.
# Find it by running: engine dashboard --solution "<solution name>"
# and copying the solution_id from the output.
VITE_SOLUTION_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Before going live ─────────────────────────────────────────────
# The anon key is embedded in the built JS. For production:
# 1. Enable Row Level Security on kpi_snapshots, roi_results, report_runs
#    in the engine Supabase and add per-solution policies, OR
# 2. Deploy each client to a separate Supabase project that only
#    contains that client's data.
# For internal / staging use, the anon key + solution_id filter is fine.

# ── PROD (deployed static build, e.g. Amplify) ───────────────────
# The Vite proxies (/rest, /baserow) only run in `vite dev`. In a static build,
# point the dashboard at the deployed `jdm-feed` edge function (supabase/functions/
# jdm-feed), which proxies BOTH Supabase and Baserow server-side (keys + the HTTP
# Baserow origin stay off the browser). Set this in the Amplify env vars.
# Leave unset for local dev (falls back to the Vite proxies).
# VITE_JDM_FEED_URL=https://<ENGINE_PROJECT_REF>.functions.supabase.co/jdm-feed
